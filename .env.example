# Wayline — variáveis de ambiente (exemplo). Copie para .env e preencha.
# Nesta fase (0) nada aqui é obrigatório — o app é mock/estático.

# --- Banco de dados (Fase 1) ---------------------------------------------
# Postgres provisionado no Easypanel. Use o HOST INTERNO (nome do serviço),
# não exponha a porta publicamente.
# Formato: postgres://<user>:<senha>@<nome-do-servico>:5432/<database>
# O APP conecta como a role wayline_app (não-superuser, sujeita a RLS).
# DATABASE_URL=postgres://wayline_app:senha@web-way_wayline-db:5432/wayline?sslmode=disable

# --- Auth.js (Fase 1.7) ---------------------------------------------------
# Segredo p/ assinar os JWT de sessão. Gere com: openssl rand -base64 32
# AUTH_SECRET=troque-por-um-segredo-aleatorio

# Senha usada pelo seed para todos os usuários de demo (default: wayline123).
# SEED_PASSWORD=wayline123
